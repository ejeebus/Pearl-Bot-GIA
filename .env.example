# Microsoft-authenticated bots sign in interactively the first time they run:
# each bot prints a microsoft.com/link device code to the console, keyed by the
# `username` set for it in config.json. After the first sign-in the token is
# cached, so no email/password is needed here. Set each bot's account via its
# `username` in config.json (one entry per account under "bots").
#
# MOJANG_PASSWORD is only used for legacy "auth": "mojang" bots.
# MOJANG_PASSWORD=your_legacy_password

# Discord bot token (optional)
DISCORD_TOKEN=your_discord_bot_token

# Discord channel ID for pearl requests
DISCORD_CHANNEL_ID=1234567890
